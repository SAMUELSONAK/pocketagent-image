#!/bin/bash
# PocketAgent Wrapper Script
# This script manages the PocketAgent service on your local machine

# Detect OS and set paths
if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS
    POCKETAGENT_ROOT="/Applications/PocketAgent"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    # Linux
    POCKETAGENT_ROOT="$HOME/.local/share/pocketagent"
else
    echo "❌ Unsupported OS: $OSTYPE"
    exit 1
fi

POCKETAGENT_HOME="$POCKETAGENT_ROOT/home"
OPENCLAW_PATH="$POCKETAGENT_ROOT/lib/openclaw"
LOG_FILE="$POCKETAGENT_ROOT/logs/pocketagent.log"

export HOME="$POCKETAGENT_HOME"
export XDG_CONFIG_HOME="$HOME/.openclaw"

# Helper function to check if agent is running
is_running() {
    pgrep -f "openclaw.*gateway" > /dev/null
}

# Main command handler
case "$1" in
    start)
        if is_running; then
            echo "📟 PocketAgent is already running"
            exit 0
        fi
        
        echo "📟 Starting PocketAgent..."
        nohup node "$OPENCLAW_PATH/dist/index.js" gateway \
            >> "$LOG_FILE" 2>&1 &
        
        sleep 2
        if is_running; then
            echo "✅ PocketAgent started successfully"
            echo "🌐 Access at: http://localhost:18789"
        else
            echo "❌ Failed to start PocketAgent"
            echo "Check logs: pocketagent logs"
            exit 1
        fi
        ;;
    
    stop)
        if ! is_running; then
            echo "📟 PocketAgent is not running"
            exit 0
        fi
        
        echo "📟 Stopping PocketAgent..."
        pkill -f "openclaw.*gateway"
        sleep 1
        
        if ! is_running; then
            echo "✅ PocketAgent stopped"
        else
            echo "⚠️  Force stopping..."
            pkill -9 -f "openclaw.*gateway"
            echo "✅ PocketAgent stopped"
        fi
        ;;
    
    restart)
        echo "📟 Restarting PocketAgent..."
        "$0" stop
        sleep 2
        "$0" start
        ;;
    
    status)
        if is_running; then
            PID=$(pgrep -f "openclaw.*gateway")
            echo "📟 PocketAgent is running (PID: $PID)"
            echo "🌐 Access at: http://localhost:18789"
        else
            echo "📟 PocketAgent is stopped"
        fi
        ;;
    
    logs)
        if [ ! -f "$LOG_FILE" ]; then
            echo "❌ Log file not found: $LOG_FILE"
            exit 1
        fi
        
        case "$2" in
            --follow|-f)
                tail -f "$LOG_FILE"
                ;;
            --tail)
                tail -n "${3:-100}" "$LOG_FILE"
                ;;
            *)
                tail -n 50 "$LOG_FILE"
                ;;
        esac
        ;;
    
    update-continue)
        # This is called after the script updates itself
        echo "📟 Continuing update with latest script..."
        echo ""
        
        # Update installer script
        echo "✓ Updating installer script..."
        INSTALLER_URL="https://raw.githubusercontent.com/PocketAgentNetwork/pocketagent-image/main/Local/install.sh"
        if curl -fsSL "$INSTALLER_URL" -o "$POCKETAGENT_ROOT/install.sh.new"; then
            chmod +x "$POCKETAGENT_ROOT/install.sh.new"
            mv "$POCKETAGENT_ROOT/install.sh.new" "$POCKETAGENT_ROOT/install.sh"
            echo "  ✓ Installer script updated"
        else
            echo "  ⚠️  Failed to update installer script (continuing anyway)"
        fi
        echo ""
        
        # Check current OpenClaw version
        CURRENT_VERSION=""
        if [ -f "$POCKETAGENT_ROOT/OPENCLAW_VERSION" ]; then
            CURRENT_VERSION=$(cat "$POCKETAGENT_ROOT/OPENCLAW_VERSION")
        fi
        
        # Get latest tested OpenClaw version
        echo "  Fetching latest OpenClaw version..."
        LATEST_VERSION=$(curl -fsSL https://raw.githubusercontent.com/PocketAgentNetwork/pocketagent-image/main/OPENCLAW_VERSION)
        
        if [ -z "$LATEST_VERSION" ]; then
            echo "❌ Failed to fetch OpenClaw version"
            exit 1
        fi
        
        echo "  Current: ${CURRENT_VERSION:-none}"
        echo "  Latest:  $LATEST_VERSION"
        
        # Only update OpenClaw if version changed
        if [ "$CURRENT_VERSION" != "$LATEST_VERSION" ]; then
            echo ""
            echo "  📦 Updating OpenClaw..."
            
            # Remember if agent was running
            AGENT_WAS_RUNNING=false
            if is_running; then
                AGENT_WAS_RUNNING=true
                echo "  Stopping agent..."
                "$0" stop
            fi
            
            # Backup current OpenClaw
            if [ -d "$OPENCLAW_PATH" ]; then
                BACKUP_NAME="openclaw.backup.$(date +%Y%m%d-%H%M%S)"
                echo "  Backing up to: $BACKUP_NAME"
                mv "$OPENCLAW_PATH" "$POCKETAGENT_ROOT/lib/$BACKUP_NAME"
            fi
            
            echo "  Downloading OpenClaw $LATEST_VERSION..."
            cd "$POCKETAGENT_ROOT/lib"
            
            # Download release tarball with progress bar
            if ! curl -L --progress-bar "https://github.com/openclaw/openclaw/archive/refs/tags/$LATEST_VERSION.tar.gz" -o openclaw.tar.gz; then
                echo "❌ Failed to download OpenClaw"
                if [ -d "$POCKETAGENT_ROOT/lib/$BACKUP_NAME" ]; then
                    echo "  Restoring backup..."
                    mv "$POCKETAGENT_ROOT/lib/$BACKUP_NAME" "$OPENCLAW_PATH"
                fi
                exit 1
            fi
            
            # Extract
            echo "  Extracting..."
            tar -xzf openclaw.tar.gz
            mv "openclaw-${LATEST_VERSION#v}" openclaw
            rm openclaw.tar.gz
            
            # Build
            echo "  Building OpenClaw..."
            cd openclaw
            
            # Ensure logs directory exists
            mkdir -p "$POCKETAGENT_ROOT/logs"
            
            # Check if pnpm is available
            if ! command -v pnpm >/dev/null 2>&1; then
                echo "❌ pnpm not found. Installing pnpm..."
                if ! npm install -g pnpm; then
                    echo "❌ Failed to install pnpm"
                    echo "  Restoring backup..."
                    cd "$POCKETAGENT_ROOT/lib"
                    rm -rf openclaw
                    mv "$BACKUP_NAME" openclaw
                    exit 1
                fi
            fi
            
            echo "  Installing dependencies (this may take a few minutes)..."
            if ! pnpm install 2>&1 | tee "$POCKETAGENT_ROOT/logs/pnpm-install.log"; then
                echo "❌ Failed to install dependencies"
                echo "  Check logs: $POCKETAGENT_ROOT/logs/pnpm-install.log"
                echo "  Restoring backup..."
                cd "$POCKETAGENT_ROOT/lib"
                rm -rf openclaw
                mv "$BACKUP_NAME" openclaw
                exit 1
            fi
            
            echo "  Building (this may take a few minutes)..."
            if ! pnpm build 2>&1 | tee "$POCKETAGENT_ROOT/logs/pnpm-build.log"; then
                echo "❌ Failed to build OpenClaw"
                echo "  Check logs: $POCKETAGENT_ROOT/logs/pnpm-build.log"
                echo "  Restoring backup..."
                cd "$POCKETAGENT_ROOT/lib"
                rm -rf openclaw
                mv "$BACKUP_NAME" openclaw
                exit 1
            fi
            
            # Verify build succeeded
            if [ ! -f "dist/index.js" ]; then
                echo "❌ Build completed but dist/index.js not found"
                echo "  Restoring backup..."
                cd "$POCKETAGENT_ROOT/lib"
                rm -rf openclaw
                mv "$BACKUP_NAME" openclaw
                exit 1
            fi
            
            # Save version info only after successful build
            echo "$LATEST_VERSION" > "$POCKETAGENT_ROOT/OPENCLAW_VERSION"
            
            echo "  ✅ OpenClaw updated to $LATEST_VERSION"
            
            # Run health check to migrate config
            echo ""
            echo "  Running health check..."
            if "$0" doctor --fix 2>&1 | tee "$POCKETAGENT_ROOT/logs/doctor.log"; then
                echo "  ✅ Health check passed"
            else
                echo "  ⚠️  Health check had warnings (check logs/doctor.log)"
            fi
            
            # Restart agent if it was running before
            if [ "$AGENT_WAS_RUNNING" = true ]; then
                echo ""
                echo "  Starting agent..."
                "$0" start
            fi
        else
            echo "  ✅ OpenClaw already up to date"
        fi
        
        # Always update workspace files
        echo ""
        echo "  📝 Updating workspace..."
        curl -fsSL https://raw.githubusercontent.com/PocketAgentNetwork/pocketagent-image/main/Local/install.sh | bash -s workspace-update
        
        echo ""
        echo "✅ PocketAgent update complete!"
        ;;
    
    update)
        echo "📟 Updating PocketAgent..."
        echo ""
        
        # Update pocketagent command script first
        echo "✓ Updating pocketagent command..."
        POCKETAGENT_URL="https://raw.githubusercontent.com/PocketAgentNetwork/pocketagent-image/main/Local/bin/pocketagent"
        if curl -fsSL "$POCKETAGENT_URL" -o "$POCKETAGENT_ROOT/bin/pocketagent.new"; then
            chmod +x "$POCKETAGENT_ROOT/bin/pocketagent.new"
            mv "$POCKETAGENT_ROOT/bin/pocketagent.new" "$POCKETAGENT_ROOT/bin/pocketagent"
            echo "  ✓ pocketagent command updated"
            echo ""
            echo "  Re-executing with updated script..."
            exec "$POCKETAGENT_ROOT/bin/pocketagent" update-continue
        else
            echo "  ⚠️  Failed to update pocketagent command (continuing with current version)"
            # If update failed, continue with current script
            exec "$POCKETAGENT_ROOT/bin/pocketagent" update-continue
        fi
        ;;
    
    fix-context)
        echo "📟 Fixing model context window..."
        cd "$OPENCLAW_PATH"
        node dist/index.js config set models.providers.pocketagent-local.models.0.contextWindow 128000
        node dist/index.js config set models.providers.pocketagent-local.models.0.maxTokens 128000
        echo ""
        echo "✅ Context window updated to 128000 tokens"
        echo "   Restart PocketAgent to apply: pocketagent restart"
        ;;
    
    restore-backup)
        echo "📟 Restoring from backup..."
        
        # Find most recent backup
        LATEST_BACKUP=$(ls -t "$POCKETAGENT_ROOT/lib" | grep "openclaw.backup" | head -1)
        
        if [ -z "$LATEST_BACKUP" ]; then
            echo "❌ No backup found"
            exit 1
        fi
        
        echo "  Found backup: $LATEST_BACKUP"
        read -p "  Restore this backup? (y/N): " -n 1 -r
        echo
        
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Restore cancelled"
            exit 0
        fi
        
        # Stop agent
        if is_running; then
            echo "  Stopping agent..."
            "$0" stop
        fi
        
        # Restore backup
        echo "  Restoring..."
        rm -rf "$OPENCLAW_PATH"
        mv "$POCKETAGENT_ROOT/lib/$LATEST_BACKUP" "$OPENCLAW_PATH"
        
        echo "  ✅ Backup restored"
        echo ""
        echo "  Starting agent..."
        "$0" start
        ;;
    
    fix-context)
        echo "📟 Fixing model context window..."
        cd "$OPENCLAW_PATH"
        node dist/index.js config set models.providers.pocketagent-local.models.0.contextWindow 128000
        node dist/index.js config set models.providers.pocketagent-local.models.0.maxTokens 128000
        echo ""
        echo "✅ Context window updated to 128000 tokens"
        echo "   Restart PocketAgent to apply: pocketagent restart"
        ;;
    
    version)
        if [ -d "$OPENCLAW_PATH/.git" ]; then
            cd "$OPENCLAW_PATH"
            COMMIT=$(git rev-parse --short HEAD)
            BRANCH=$(git rev-parse --abbrev-ref HEAD)
            echo "📟 PocketAgent (OpenClaw)"
            echo "   Branch: $BRANCH"
            echo "   Commit: $COMMIT"
        else
            echo "❌ Unable to determine version"
        fi
        ;;
    
    doctor)
        if ! is_running; then
            echo "⚠️  PocketAgent is not running"
            echo "   Start it with: pocketagent start"
            exit 1
        fi
        
        cd "$OPENCLAW_PATH"
        node dist/index.js doctor "$@"
        ;;
    
    models|config|workspace|skills|integrations|health)
        if ! is_running; then
            echo "⚠️  PocketAgent is not running"
            echo "   Start it with: pocketagent start"
            exit 1
        fi
        
        cd "$OPENCLAW_PATH"
        node dist/index.js "$@"
        ;;
    
    enable)
        echo "📟 Enabling auto-start on boot..."
        
        if [[ "$OSTYPE" == "darwin"* ]]; then
            # macOS - launchd
            PLIST_FILE="$HOME/Library/LaunchAgents/com.pocketagent.plist"
            
            if [ ! -f "$PLIST_FILE" ]; then
                echo "  Creating launchd service..."
                mkdir -p "$HOME/Library/LaunchAgents"
                
                cat > "$PLIST_FILE" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pocketagent</string>
    <key>ProgramArguments</key>
    <array>
        <string>$POCKETAGENT_ROOT/bin/pocketagent</string>
        <string>start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>$POCKETAGENT_ROOT/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>$POCKETAGENT_ROOT/logs/launchd.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$POCKETAGENT_ROOT/bin</string>
    </dict>
</dict>
</plist>
EOF
            fi
            
            launchctl unload "$PLIST_FILE" 2>/dev/null || true
            launchctl load "$PLIST_FILE"
            echo "✅ Auto-start enabled (launchd)"
            
        elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
            # Linux - systemd
            SERVICE_FILE="$HOME/.config/systemd/user/pocketagent.service"
            
            if [ ! -f "$SERVICE_FILE" ]; then
                echo "  Creating systemd service..."
                mkdir -p "$HOME/.config/systemd/user"
                
                cat > "$SERVICE_FILE" << EOF
[Unit]
Description=PocketAgent - Personal AI Agent
After=network.target

[Service]
Type=simple
ExecStart=$POCKETAGENT_ROOT/bin/pocketagent start
ExecStop=$POCKETAGENT_ROOT/bin/pocketagent stop
Restart=on-failure
RestartSec=10
StandardOutput=append:$POCKETAGENT_ROOT/logs/systemd.out.log
StandardError=append:$POCKETAGENT_ROOT/logs/systemd.err.log
Environment="PATH=/usr/local/bin:/usr/bin:/bin:$POCKETAGENT_ROOT/bin"

[Install]
WantedBy=default.target
EOF
            fi
            
            systemctl --user daemon-reload
            systemctl --user enable pocketagent.service
            loginctl enable-linger "$USER" 2>/dev/null || true
            echo "✅ Auto-start enabled (systemd)"
            
        else
            echo "❌ Auto-start not supported on this OS"
            exit 1
        fi
        ;;
    
    disable)
        echo "📟 Disabling auto-start on boot..."
        
        if [[ "$OSTYPE" == "darwin"* ]]; then
            # macOS - launchd
            PLIST_FILE="$HOME/Library/LaunchAgents/com.pocketagent.plist"
            
            if [ -f "$PLIST_FILE" ]; then
                launchctl unload "$PLIST_FILE" 2>/dev/null || true
                rm "$PLIST_FILE"
                echo "✅ Auto-start disabled (launchd removed)"
            else
                echo "⚠️  Auto-start was not enabled"
            fi
            
        elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
            # Linux - systemd
            SERVICE_FILE="$HOME/.config/systemd/user/pocketagent.service"
            
            if [ -f "$SERVICE_FILE" ]; then
                systemctl --user stop pocketagent.service 2>/dev/null || true
                systemctl --user disable pocketagent.service 2>/dev/null || true
                rm "$SERVICE_FILE"
                systemctl --user daemon-reload
                echo "✅ Auto-start disabled (systemd removed)"
            else
                echo "⚠️  Auto-start was not enabled"
            fi
            
        else
            echo "❌ Auto-start not supported on this OS"
            exit 1
        fi
        ;;
    
    --help|-h|help)
        cat << EOF
📟 PocketAgent - Local AI Agent

Usage: pocketagent <command> [options]

Commands:
  start              Start PocketAgent service
  stop               Stop PocketAgent service
  restart            Restart PocketAgent service
  status             Check if PocketAgent is running
  logs               View logs (--follow, --tail N)
  update             Update to latest OpenClaw version
  restore-backup     Restore from most recent backup
  version            Show current version
  fix-context        Fix model context window (set to 128k tokens)
  
  enable             Enable auto-start on boot
  disable            Disable auto-start on boot
  
  doctor             Run diagnostics (--fix to auto-fix)
  models             Manage AI models
  config             View/edit configuration
  workspace          Manage workspace
  skills             Manage skills
  integrations       Manage integrations
  health             Check agent health
  
  --help, -h         Show this help message

All other OpenClaw commands are also available:
  pocketagent <openclaw-command> [options]
  
  Examples:
    pocketagent channels login
    pocketagent message send --target +1234567890 --message "Hi"
    pocketagent agents list
    pocketagent browser open

Examples:
  pocketagent start
  pocketagent logs --follow
  pocketagent update
  pocketagent models status
  pocketagent doctor --fix
  pocketagent fix-context
  pocketagent enable    # Enable auto-start on boot
  pocketagent disable   # Disable auto-start on boot

Web UI: http://localhost:18789
EOF
        ;;
    
    *)
        # Pass any other command directly to openclaw
        if [ "$1" != "" ]; then
            cd "$OPENCLAW_PATH"
            node dist/index.js "$@"
        else
            echo "❌ No command specified"
            echo "Run 'pocketagent --help' for usage"
            exit 1
        fi
        ;;
esac
